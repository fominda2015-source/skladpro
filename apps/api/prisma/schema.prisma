generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum OperationType {
  INCOME
  EXPENSE
  TRANSFER
}

enum StockMovementDirection {
  IN
  OUT
}

enum IssueRequestStatus {
  DRAFT
  ON_APPROVAL
  APPROVED
  REJECTED
  ISSUED
  CANCELLED
}

enum IssueBasisType {
  PROJECT_WORK
  INTERNAL_NEED
  EMERGENCY
  OTHER
}

enum ToolStatus {
  IN_STOCK
  ISSUED
  IN_REPAIR
  DAMAGED
  LOST
  WRITTEN_OFF
  DISPUTED
}

enum TransportWaybillStatus {
  DRAFT
  FORMED
  SHIPPED
  RECEIVED
  CLOSED
}

enum MaterialMatchQueueStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum IntegrationJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum NotificationLevel {
  INFO
  WARNING
  ERROR
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  passwordHash     String
  fullName         String
  avatarUrl        String?
  status           UserStatus           @default(ACTIVE)
  roleId           String
  role             Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  actionLogs       ActionLog[]
  auditLogs        AuditLog[]
  warehouseScopes  UserWarehouseScope[]
  projectScopes    UserProjectScope[]
  createdIssues    IssueRequest[]       @relation("IssueCreatedBy")
  approvedIssues   IssueRequest[]       @relation("IssueApprovedBy")
  documentLinks    DocumentLink[]
  materialMerges   MaterialMergeHistory[]
  notifications    Notification[]       @relation("NotificationRecipient")
  assignedTasks    StaffTask[]          @relation("StaffTaskAssignee")
  createdTasks     StaffTask[]          @relation("StaffTaskCreator")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model StaffTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("OPEN")
  assigneeId  String
  createdById String
  projectId   String?
  warehouseId String?
  dueAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee    User      @relation("StaffTaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("StaffTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
}

model UserWarehouseScope {
  id          String    @id @default(cuid())
  userId      String
  warehouseId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, warehouseId])
}

model UserProjectScope {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Warehouse {
  id          String       @id @default(cuid())
  name        String
  address     String?
  isActive    Boolean      @default(true)
  stocks      Stock[]
  stockMovements StockMovement[]
  operations  Operation[]
  issues      IssueRequest[]
  tools       Tool[]
  waybillsFrom TransportWaybill[] @relation("WaybillFromWarehouse")
  userScopes  UserWarehouseScope[]
  staffTasks  StaffTask[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Material {
  id              String              @id @default(cuid())
  sku             String?             @unique
  name            String
  unit            String
  category        String?
  mergedIntoId    String?
  synonyms        MaterialSynonym[]
  matchSuggestions MaterialMatchQueue[] @relation("MatchSuggestion")
  matchResolved    MaterialMatchQueue[] @relation("MatchResolved")
  stocks          Stock[]
  operationItems  OperationItem[]
  limitItems      ProjectLimitItem[]
  issueItems      IssueRequestItem[]
  waybillItems    TransportWaybillItem[]
  stockMovements  StockMovement[]
  mergedInto      Material?            @relation("MaterialMergedInto", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom      Material[]           @relation("MaterialMergedInto")
  mergeHistoryFrom MaterialMergeHistory[] @relation("MergeSource")
  mergeHistoryTo  MaterialMergeHistory[] @relation("MergeTarget")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model MaterialMergeHistory {
  id               String   @id @default(cuid())
  sourceMaterialId String
  targetMaterialId String
  actorId          String?
  reason           String?
  payload          Json?
  createdAt        DateTime @default(now())
  sourceMaterial   Material @relation("MergeSource", fields: [sourceMaterialId], references: [id], onDelete: Restrict)
  targetMaterial   Material @relation("MergeTarget", fields: [targetMaterialId], references: [id], onDelete: Restrict)
  actor            User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([sourceMaterialId, createdAt])
  @@index([targetMaterialId, createdAt])
}

model StockMovement {
  id                   String                 @id @default(cuid())
  warehouseId          String
  materialId           String
  quantity             Decimal                @db.Decimal(14, 3)
  direction            StockMovementDirection
  sourceDocumentType   String
  sourceDocumentId     String?
  operationId          String?
  issueRequestId       String?
  note                 String?
  createdById          String?
  createdAt            DateTime               @default(now())
  warehouse            Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  material             Material               @relation(fields: [materialId], references: [id], onDelete: Restrict)
  operation            Operation?             @relation(fields: [operationId], references: [id], onDelete: SetNull)
  issueRequest         IssueRequest?          @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)

  @@index([warehouseId, materialId, createdAt])
  @@index([operationId])
  @@index([issueRequestId])
  @@index([sourceDocumentType, sourceDocumentId])
}

model MaterialSynonym {
  id          String   @id @default(cuid())
  materialId  String
  value       String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([materialId, value])
}

model Stock {
  id            String     @id @default(cuid())
  warehouseId   String
  materialId    String
  quantity      Decimal    @db.Decimal(14, 3)
  reserved      Decimal    @default(0) @db.Decimal(14, 3)
  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  material      Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  updatedAt     DateTime   @updatedAt

  @@unique([warehouseId, materialId])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  code        String?         @unique
  limits      ProjectLimit[]
  operations  Operation[]
  issues      IssueRequest[]
  tools       Tool[]
  userScopes  UserProjectScope[]
  staffTasks  StaffTask[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectLimit {
  id          String             @id @default(cuid())
  projectId   String
  name        String
  version     Int                @default(1)
  items       ProjectLimitItem[]
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ProjectLimitItem {
  id              String       @id @default(cuid())
  projectLimitId  String
  materialId      String
  plannedQty      Decimal      @db.Decimal(14, 3)
  issuedQty       Decimal      @default(0) @db.Decimal(14, 3)
  reservedQty     Decimal      @default(0) @db.Decimal(14, 3)
  projectLimit    ProjectLimit @relation(fields: [projectLimitId], references: [id], onDelete: Cascade)
  material        Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([projectLimitId, materialId])
}

model Operation {
  id              String          @id @default(cuid())
  type            OperationType
  warehouseId     String
  projectId       String?
  documentNumber  String?
  status          String          @default("DRAFT")
  operationDate   DateTime        @default(now())
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items           OperationItem[]
  documents       OperationDocument[]
  issueRequestId  String?
  issueRequest    IssueRequest?   @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)
  waybills        TransportWaybill[]
  stockMovements  StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OperationItem {
  id            String      @id @default(cuid())
  operationId   String
  materialId    String
  quantity      Decimal     @db.Decimal(14, 3)
  price         Decimal?    @db.Decimal(14, 2)
  operation     Operation   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  material      Material    @relation(fields: [materialId], references: [id], onDelete: Restrict)
}

model OperationDocument {
  id            String      @id @default(cuid())
  operationId   String
  type          String
  fileName      String
  filePath      String
  operation     Operation   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model ActionLog {
  id            String      @id @default(cuid())
  userId        String
  action        String
  entityType    String
  entityId      String
  payload       Json?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentFile {
  id         String   @id @default(cuid())
  groupId    String?
  version    Int      @default(1)
  entityType String
  entityId   String
  type       String
  fileName   String
  filePath   String
  mimeType   String?
  size       Int?
  checksumSha256 String?
  createdBy  String
  replacedById String?
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  links      DocumentLink[]

  @@index([groupId, version])
  @@index([entityType, entityId])
  @@index([checksumSha256])
}

model DocumentLink {
  id             String       @id @default(cuid())
  documentFileId String
  entityType     String
  entityId       String
  createdAt      DateTime     @default(now())
  createdById    String
  documentFile   DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Cascade)
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([documentFileId, entityType, entityId])
  @@index([entityType, entityId])
}

model MaterialMatchQueue {
  id                  String                   @id @default(cuid())
  rawName             String
  normalizedName      String
  unit                String?
  article             String?
  status              MaterialMatchQueueStatus @default(PENDING)
  confidence          Float?
  suggestedMaterialId String?
  resolvedMaterialId  String?
  source              String?
  createdById         String?
  suggestedMaterial   Material?                @relation("MatchSuggestion", fields: [suggestedMaterialId], references: [id], onDelete: SetNull)
  resolvedMaterial    Material?                @relation("MatchResolved", fields: [resolvedMaterialId], references: [id], onDelete: SetNull)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status])
  @@index([normalizedName])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  beforeData Json?
  afterData  Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model IntegrationJob {
  id          String               @id @default(cuid())
  kind        String
  status      IntegrationJobStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  requestedBy String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([kind, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  title       String
  message     String
  level       NotificationLevel @default(INFO)
  isRead      Boolean           @default(false)
  entityType  String?
  entityId    String?
  createdAt   DateTime          @default(now())
  readAt      DateTime?
  user        User              @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Tool {
  id              String     @id @default(cuid())
  name            String
  inventoryNumber String     @unique
  serialNumber    String?
  qrCode          String     @unique
  status          ToolStatus @default(IN_STOCK)
  warehouseId     String?
  projectId       String?
  responsible     String?
  note            String?
  warehouse       Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  project         Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  events          ToolEvent[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model ToolEvent {
  id        String   @id @default(cuid())
  toolId    String
  action    String
  status    ToolStatus
  comment   String?
  actorId   String?
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model IssueRequest {
  id            String             @id @default(cuid())
  number        String             @unique
  status        IssueRequestStatus @default(DRAFT)
  basisType     IssueBasisType     @default(OTHER)
  basisRef      String?
  warehouseId   String
  projectId     String?
  requestedById String
  approvedById  String?
  note          String?
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestedBy   User               @relation("IssueCreatedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy    User?              @relation("IssueApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  items         IssueRequestItem[]
  operations    Operation[]
  waybills      TransportWaybill[]
  stockMovements StockMovement[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model IssueRequestItem {
  id             String       @id @default(cuid())
  issueRequestId String
  materialId     String
  quantity       Decimal      @db.Decimal(14, 3)
  issueRequest   IssueRequest @relation(fields: [issueRequestId], references: [id], onDelete: Cascade)
  material       Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)
}

model TransportWaybill {
  id                 String                @id @default(cuid())
  number             String                @unique
  status             TransportWaybillStatus @default(DRAFT)
  fromWarehouseId    String?
  toLocation         String
  sender             String?
  recipient          String?
  vehicle            String?
  driverName         String?
  route              String?
  operationId        String?
  issueRequestId     String?
  shippedAt          DateTime?
  receivedAt         DateTime?
  closedAt           DateTime?
  fromWarehouse      Warehouse?            @relation("WaybillFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  operation          Operation?            @relation(fields: [operationId], references: [id], onDelete: SetNull)
  issueRequest       IssueRequest?         @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)
  items              TransportWaybillItem[]
  events             TransportWaybillEvent[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model TransportWaybillItem {
  id                 String            @id @default(cuid())
  transportWaybillId String
  materialId         String
  quantity           Decimal           @db.Decimal(14, 3)
  transportWaybill   TransportWaybill  @relation(fields: [transportWaybillId], references: [id], onDelete: Cascade)
  material           Material          @relation(fields: [materialId], references: [id], onDelete: Restrict)
}

model TransportWaybillEvent {
  id                 String            @id @default(cuid())
  transportWaybillId String
  status             TransportWaybillStatus
  comment            String?
  createdAt          DateTime          @default(now())
  transportWaybill   TransportWaybill  @relation(fields: [transportWaybillId], references: [id], onDelete: Cascade)
}
