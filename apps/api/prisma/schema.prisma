generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum OperationType {
  INCOME
  EXPENSE
  TRANSFER
}

enum StockMovementDirection {
  IN
  OUT
}

enum IssueRequestStatus {
  DRAFT
  ON_APPROVAL
  APPROVED
  REJECTED
  ISSUED
  CANCELLED
}

enum IssueBasisType {
  PROJECT_WORK
  INTERNAL_NEED
  EMERGENCY
  OTHER
}

enum IssueFlowType {
  REQUEST
  DIRECT_ISSUE
}

enum IssueRequestDomain {
  MATERIALS
  TOOLS
  CONSUMABLES
  WORKWEAR
}

enum MaterialKind {
  MATERIAL
  CONSUMABLE
  WORKWEAR
}

enum ToolStatus {
  IN_STOCK
  ISSUED
  IN_REPAIR
  DAMAGED
  LOST
  WRITTEN_OFF
  DISPUTED
}

enum TransportWaybillStatus {
  DRAFT
  FORMED
  SHIPPED
  RECEIVED
  CLOSED
}

enum IntegrationJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum NotificationLevel {
  INFO
  WARNING
  ERROR
}

enum ConversationKind {
  DM
  FEEDBACK
}

enum ObjectSection {
  SS
  EOM
}

enum ReceiptRequestStatus {
  NEW
  IN_PROGRESS
  RECEIVED
  CANCELLED
}

enum ReceiptItemCategory {
  EQUIPMENT
  CONSUMABLE
  CABLE
  TOOL_MANUAL
  TOOL_ELECTRIC_CORDLESS
  TOOL_ELECTRIC_CORDED
  PPE
  TOOL_CONSUMABLE
  KIP
  TOWERS_LADDERS
  CAMP_CONTAINER_CABIN
  CAMP_FURNITURE
  CAMP_OFFICE_EQUIPMENT
  CAMP_APPLIANCES
  CAMP_OTHER
  OTHER
}

enum ToolCatalogSection {
  TOOL_MANUAL
  TOOL_ELECTRIC_CORDLESS
  TOOL_ELECTRIC_CORDED
  PPE
  TOOL_CONSUMABLE
  KIP
  TOWERS_LADDERS
  OTHER
}

enum StockCondition {
  NEW
  USED
}

enum FeedbackTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_REPLY
  RESOLVED
  CLOSED
}

enum TransferRequestStatus {
  NEW
  APPROVED
  REJECTED
  DONE
  CANCELLED
}

enum LimitNodeType {
  GROUP
  MATERIAL
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  phone            String?
  passwordHash     String
  fullName         String
  avatarUrl        String?
  status           UserStatus           @default(ACTIVE)
  roleId           String
  role             Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)
  customPermissions Json?
  positionId       String?
  /** Материально ответственное лицо — участник материального отчёта. */
  isMol            Boolean              @default(false)
  activeWarehouseId String?
  activeSection    ObjectSection?
  position         Position?            @relation(fields: [positionId], references: [id], onDelete: SetNull)
  activeWarehouse  Warehouse?           @relation("UserActiveWarehouse", fields: [activeWarehouseId], references: [id], onDelete: SetNull)
  actionLogs       ActionLog[]
  auditLogs        AuditLog[]
  warehouseScopes  UserWarehouseScope[]
  warehouseSectionScopes UserWarehouseSectionScope[]
  projectScopes    UserProjectScope[]
  createdIssues    IssueRequest[]       @relation("IssueCreatedBy")
  approvedIssues   IssueRequest[]       @relation("IssueApprovedBy")
  documentLinks    DocumentLink[]
  notifications    Notification[]       @relation("NotificationRecipient")
  notificationRules NotificationRule[]  @relation("NotificationRuleOwner")
  conversationParticipants ConversationParticipant[]
  sentMessages     Message[]            @relation("MessageSender")
  limitTemplates   ObjectLimitTemplate[] @relation("LimitTemplateCreator")
  materialMappings MaterialMappingLibrary[]
  receiptRequests  ReceiptRequest[]      @relation("ReceiptRequestCreator")
  campItems        CampItem[]            @relation("CampItemCreator")
  revertedAuditLogs AuditLog[]           @relation("AuditRevertedBy")
  feedbackTicketsAuthored FeedbackTicket[] @relation("FeedbackTicketAuthor")
  feedbackTicketMessagesSent FeedbackTicketMessage[] @relation("FeedbackTicketMessageSender")
  transferRequestsRequested TransferRequest[]
  announcementsCreated Announcement[] @relation("AnnouncementAuthor")
  materialWriteoffsHeld   MaterialHolderWriteoff[] @relation("MaterialWriteoffHolder")
  materialWriteoffsActed  MaterialHolderWriteoff[] @relation("MaterialWriteoffActor")
  responsibleWarehouses   Warehouse[]          @relation("WarehouseResponsible")
  productivitySheetsCreated ProductivitySheet[] @relation("ProductivitySheetCreator")
  dataJobRuns             DataJobRun[]             @relation("DataJobRunTriggeredBy")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model Position {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserWarehouseScope {
  id          String    @id @default(cuid())
  userId      String
  warehouseId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, warehouseId])
}

model UserWarehouseSectionScope {
  id          String        @id @default(cuid())
  userId      String
  warehouseId String
  section     ObjectSection
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@unique([userId, warehouseId, section])
  @@index([warehouseId, section])
}

model UserProjectScope {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Warehouse {
  id          String       @id @default(cuid())
  name        String
  address     String?
  isActive    Boolean      @default(true)
  responsibleUserId String?
  responsibleUser   User?  @relation("WarehouseResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  stocks      Stock[]
  stockMovements StockMovement[]
  operations  Operation[]
  issues      IssueRequest[]
  tools       Tool[]
  waybillsFrom TransportWaybill[] @relation("WaybillFromWarehouse")
  userScopes  UserWarehouseScope[]
  activeUsers User[]           @relation("UserActiveWarehouse")
  userSectionScopes UserWarehouseSectionScope[]
  projectLinks ProjectWarehouse[]
  projects    Project[]      @relation("ProjectWarehouseMain")
  limitTemplates ObjectLimitTemplate[]
  materialMappings MaterialMappingLibrary[]
  receiptRequests ReceiptRequest[]
  campItems   CampItem[]
  transferRequestsFrom TransferRequest[] @relation("TransferFromWh")
  transferRequestsTo   TransferRequest[] @relation("TransferToWh")
  materialHolderWriteoffs MaterialHolderWriteoff[]
  toolConsumableIssues ToolConsumableIssue[]
  productivitySheets ProductivitySheet[]
  auditLogs   AuditLog[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Material {
  id              String              @id @default(cuid())
  sku             String?             @unique
  name            String
  unit            String
  kind            MaterialKind        @default(MATERIAL)
  unitPrice       Decimal?            @db.Decimal(14, 2)
  /// Кол-во единиц, за которое указана сумма в unitPrice (из прихода или карточки).
  priceBasisQty   Decimal?            @db.Decimal(14, 3)
  category        String?
  toolCatalogSection ToolCatalogSection?
  mergedIntoId    String?
  synonyms        MaterialSynonym[]
  stocks          Stock[]
  operationItems  OperationItem[]
  limitItems      ProjectLimitItem[]
  issueItems      IssueRequestItem[]
  waybillItems    TransportWaybillItem[]
  stockMovements  StockMovement[]
  limitNodes      ObjectLimitNode[]
  mappingTargets  MaterialMappingLibrary[]
  receiptMappedItems ReceiptRequestItem[]
  transferRequestLines TransferRequestLine[]
  mergedInto      Material?            @relation("MaterialMergedInto", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom      Material[]           @relation("MaterialMergedInto")
  materialHolderWriteoffs MaterialHolderWriteoff[]
  toolConsumableIssues ToolConsumableIssue[]
  toolCatalogConsumableEvents ToolCatalogConsumableEvent[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

/// Журнал одноразовых переформирований данных (при смене правил — новый id, скрипт выполняется снова).
model DataMigration {
  id        String   @id
  summary   String?
  appliedAt DateTime @default(now())
}

/// История запусков задач обслуживания БД (админка + деплой).
model DataJobRun {
  id            String    @id @default(cuid())
  jobId         String
  deployVersion String?
  status        String
  summary       String?
  error         String?
  forced        Boolean   @default(false)
  triggeredById String?
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  triggeredBy   User?     @relation("DataJobRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)

  @@index([jobId, startedAt])
  @@index([jobId, deployVersion, status])
}

model StockMovement {
  id                   String                 @id @default(cuid())
  warehouseId          String
  materialId           String
  quantity             Decimal                @db.Decimal(14, 3)
  direction            StockMovementDirection
  sourceDocumentType   String
  sourceDocumentId     String?
  operationId          String?
  issueRequestId       String?
  note                 String?
  createdById          String?
  createdAt            DateTime               @default(now())
  warehouse            Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  material             Material               @relation(fields: [materialId], references: [id], onDelete: Restrict)
  operation            Operation?             @relation(fields: [operationId], references: [id], onDelete: SetNull)
  issueRequest         IssueRequest?          @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)

  @@index([warehouseId, materialId, createdAt])
  @@index([operationId])
  @@index([issueRequestId])
  @@index([sourceDocumentType, sourceDocumentId])
}

model MaterialSynonym {
  id          String   @id @default(cuid())
  materialId  String
  value       String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([materialId, value])
}

model Stock {
  id            String     @id @default(cuid())
  warehouseId   String
  materialId    String
  section       ObjectSection @default(SS)
  condition     StockCondition @default(NEW)
  quantity      Decimal    @db.Decimal(14, 3)
  reserved      Decimal    @default(0) @db.Decimal(14, 3)
  storageRoom   String?
  storageCell   String?
  catalogDisputed Boolean @default(false)
  catalogNote     String?
  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  material      Material   @relation(fields: [materialId], references: [id], onDelete: Cascade)
  updatedAt     DateTime   @updatedAt

  @@unique([warehouseId, materialId, section, condition])
}

model ToolCatalogConsumableEvent {
  id          String          @id @default(cuid())
  stockId     String?
  materialId  String
  warehouseId String
  section     ObjectSection
  condition   StockCondition
  action      String
  comment     String?
  actorId     String?
  createdAt   DateTime        @default(now())
  material    Material        @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId, warehouseId, createdAt])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  code        String?         @unique
  section     ObjectSection   @default(SS)
  warehouseId String?
  warehouse   Warehouse?      @relation("ProjectWarehouseMain", fields: [warehouseId], references: [id], onDelete: SetNull)
  limits      ProjectLimit[]
  operations  Operation[]
  issues      IssueRequest[]
  tools       Tool[]
  userScopes  UserProjectScope[]
  warehouseLinks ProjectWarehouse[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectWarehouse {
  id          String    @id @default(cuid())
  projectId   String
  warehouseId String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([projectId, warehouseId])
  @@index([warehouseId])
}

model ProjectLimit {
  id          String             @id @default(cuid())
  projectId   String
  name        String
  version     Int                @default(1)
  items       ProjectLimitItem[]
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ProjectLimitItem {
  id              String       @id @default(cuid())
  projectLimitId  String
  materialId      String
  plannedQty      Decimal      @db.Decimal(14, 3)
  issuedQty       Decimal      @default(0) @db.Decimal(14, 3)
  reservedQty     Decimal      @default(0) @db.Decimal(14, 3)
  sourceNodeId    String?
  projectLimit    ProjectLimit @relation(fields: [projectLimitId], references: [id], onDelete: Cascade)
  material        Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@unique([projectLimitId, materialId])
}

model Operation {
  id              String          @id @default(cuid())
  type            OperationType
  warehouseId     String
  section         ObjectSection   @default(SS)
  projectId       String?
  documentNumber  String?
  status          String          @default("DRAFT")
  operationDate   DateTime        @default(now())
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items           OperationItem[]
  documents       OperationDocument[]
  issueRequestId  String?
  issueRequest    IssueRequest?   @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)
  waybills        TransportWaybill[]
  stockMovements  StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OperationItem {
  id            String      @id @default(cuid())
  operationId   String
  materialId    String
  quantity      Decimal     @db.Decimal(14, 3)
  price         Decimal?    @db.Decimal(14, 2)
  operation     Operation   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  material      Material    @relation(fields: [materialId], references: [id], onDelete: Restrict)
}

model OperationDocument {
  id            String      @id @default(cuid())
  operationId   String
  type          String
  fileName      String
  filePath      String
  operation     Operation   @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model ActionLog {
  id            String      @id @default(cuid())
  userId        String
  action        String
  entityType    String
  entityId      String
  payload       Json?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentFile {
  id         String   @id @default(cuid())
  groupId    String?
  version    Int      @default(1)
  entityType String
  entityId   String
  type       String
  fileName   String
  filePath   String
  mimeType   String?
  size       Int?
  checksumSha256 String?
  createdBy  String
  replacedById String?
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  links      DocumentLink[]

  @@index([groupId, version])
  @@index([entityType, entityId])
  @@index([checksumSha256])
}

model DocumentLink {
  id             String       @id @default(cuid())
  documentFileId String
  entityType     String
  entityId       String
  createdAt      DateTime     @default(now())
  createdById    String
  documentFile   DocumentFile @relation(fields: [documentFileId], references: [id], onDelete: Cascade)
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([documentFileId, entityType, entityId])
  @@index([entityType, entityId])
}

model AuditLog {
  id           String    @id @default(cuid())
  userId       String
  action       String
  entityType   String
  entityId     String
  warehouseId  String?
  summary      String?
  beforeData   Json?
  afterData    Json?
  ip           String?
  userAgent    String?
  reverted     Boolean   @default(false)
  revertedAt   DateTime?
  revertedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  revertedBy   User?     @relation("AuditRevertedBy", fields: [revertedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([warehouseId])
  @@index([userId])
  @@index([createdAt])
  @@index([reverted])
}

model IntegrationJob {
  id          String               @id @default(cuid())
  kind        String
  status      IntegrationJobStatus @default(PENDING)
  payload     Json?
  result      Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  requestedBy String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([kind, createdAt])
  @@index([status, createdAt])
}

model Notification {
  id          String            @id @default(cuid())
  userId      String
  title       String
  message     String
  level       NotificationLevel @default(INFO)
  isRead      Boolean           @default(false)
  entityType  String?
  entityId    String?
  eventCode   String?
  createdAt   DateTime          @default(now())
  readAt      DateTime?
  user        User              @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([eventCode])
}

// Правило подписки: кому отправлять уведомления по конкретному событию.
// Список eventCode задан в коде (см. apps/api/src/lib/notificationEvents.ts).
model NotificationRule {
  id        String   @id @default(cuid())
  userId    String
  eventCode String
  enabled   Boolean  @default(true)
  level     NotificationLevel?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("NotificationRuleOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventCode])
  @@index([eventCode, enabled])
}

// Глобальные настройки приложения: универсальные пороги, флаги, и т.п.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Tool {
  id              String     @id @default(cuid())
  name            String
  inventoryNumber String     @unique
  serialNumber    String?
  qrCode          String     @unique
  status          ToolStatus @default(IN_STOCK)
  warehouseId     String?
  section         ObjectSection   @default(SS)
  projectId       String?
  responsible     String?
  note            String?
  brand           String?
  toolType        String?
  categoryId      String?
  kitComplete     Boolean    @default(true)
  kitMissingNote  String?
  /// Стоимость учётной единицы (сумма за 1 инструмент/СИЗ), ₽
  purchasePrice   Decimal?   @db.Decimal(14, 2)
  warehouse       Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  project         Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category        ToolCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  events          ToolEvent[]
  issueLines      IssueRequestToolItem[]
  consumableIssues ToolConsumableIssue[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([categoryId])
  @@index([name])
}

model ToolCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String?  @unique
  icon      String?
  order     Int      @default(0)
  parentId  String?
  parent    ToolCategory?  @relation("ToolCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ToolCategory[] @relation("ToolCategoryTree")
  tools     Tool[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model ToolConsumableIssue {
  id               String        @id @default(cuid())
  toolId           String
  materialId       String
  warehouseId      String
  section          ObjectSection @default(SS)
  issueRequestId   String?
  qtyIssued        Decimal       @db.Decimal(14, 3)
  qtyReturnedNew   Decimal       @default(0) @db.Decimal(14, 3)
  qtyReturnedUsed  Decimal       @default(0) @db.Decimal(14, 3)
  qtyWrittenOff    Decimal       @default(0) @db.Decimal(14, 3)
  holderName       String?
  status           String        @default("OPEN")
  writeoffReason   String?
  tool             Tool          @relation(fields: [toolId], references: [id], onDelete: Cascade)
  material         Material      @relation(fields: [materialId], references: [id], onDelete: Restrict)
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([toolId, status])
  @@index([warehouseId, section])
}

model ToolEvent {
  id        String   @id @default(cuid())
  toolId    String
  action    String
  status    ToolStatus
  comment   String?
  actorId   String?
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String                    @id @default(cuid())
  kind         ConversationKind          @default(DM)
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId, createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileName  String
  mimeType  String?
  dataUrl   String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Announcement {
  id          String                   @id @default(cuid())
  title       String
  body        String
  isPinned    Boolean                  @default(false)
  authorId    String?
  author      User?                    @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  expiresAt   DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  attachments AnnouncementAttachment[]

  @@index([expiresAt, createdAt])
}

model AnnouncementAttachment {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  fileName       String
  filePath       String
  mimeType       String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([announcementId, sortOrder])
}

model FeedbackTicket {
  id        String               @id @default(cuid())
  seq       Int                  @unique @default(autoincrement())
  authorId  String
  subject   String               @default("")
  status    FeedbackTicketStatus @default(OPEN)
  author    User                 @relation("FeedbackTicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  messages  FeedbackTicketMessage[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([authorId, createdAt])
  @@index([status, createdAt])
}

model FeedbackTicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  text        String
  ticket      FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User           @relation("FeedbackTicketMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  attachments FeedbackTicketAttachment[]
  createdAt   DateTime @default(now())

  @@index([ticketId, createdAt])
}

model FeedbackTicketAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileName  String
  mimeType  String?
  dataUrl   String
  message   FeedbackTicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model TransferRequest {
  id              String                @id @default(cuid())
  seq             Int                   @unique @default(autoincrement())
  fromWarehouseId String
  toWarehouseId   String
  section         ObjectSection
  requestedById   String
  approvedById    String?
  receivedById    String?
  status          TransferRequestStatus @default(NEW)
  note            String?
  approvedAt      DateTime?
  receivedAt      DateTime?
  fromWarehouse   Warehouse @relation("TransferFromWh", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse     Warehouse @relation("TransferToWh", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  requestedBy     User      @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  lines           TransferRequestLine[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([toWarehouseId, status, createdAt])
  @@index([fromWarehouseId, status, createdAt])
}

model TransferRequestLine {
  id                String @id @default(cuid())
  transferRequestId String
  materialId        String
  quantity          Decimal @db.Decimal(14, 3)
  limitNodeId       String?
  transferRequest   TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)
  material          Material        @relation(fields: [materialId], references: [id], onDelete: Restrict)
  limitNode         ObjectLimitNode? @relation(fields: [limitNodeId], references: [id], onDelete: SetNull)

  @@index([transferRequestId])
}

/** Списание материала с учёта у ответственного (прораб и т.п.) — см. вкладку «Материальный отчёт». */
model MaterialHolderWriteoff {
  id             String        @id @default(cuid())
  warehouseId    String
  section        ObjectSection @default(SS)
  /** Ключ держателя: __storekeeper__ | person:… | user:… (legacy) */
  holderKey      String
  holderName     String
  holderUserId   String?
  materialId     String
  quantity       Decimal       @db.Decimal(14, 3)
  actorUserId    String
  comment        String?
  documentFileId String?
  createdAt      DateTime      @default(now())

  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  holderUser User?     @relation("MaterialWriteoffHolder", fields: [holderUserId], references: [id], onDelete: Restrict)
  actorUser  User      @relation("MaterialWriteoffActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  material   Material  @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([warehouseId, section, holderKey])
  @@index([warehouseId, section, holderUserId])
  @@index([createdAt])
}

model IssueRequest {
  id            String             @id @default(cuid())
  number        String             @unique
  status        IssueRequestStatus @default(DRAFT)
  flowType      IssueFlowType      @default(REQUEST)
  domain        IssueRequestDomain @default(MATERIALS)
  /** Путь раздела/подраздела лимита для печати в акте («Раздел: …») */
  limitReleasePath String?
  basisType     IssueBasisType     @default(OTHER)
  basisRef      String?
  responsibleName String?
  actualRecipientName String?
  warehouseId   String
  section       ObjectSection   @default(SS)
  /** Списание остатка с другого корпуса (СС/ЭОМ), если приход был там; учёт выдачи — в section */
  stockSection  ObjectSection?
  projectId     String?
  requestedById String
  approvedById  String?
  note          String?
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  project       Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestedBy   User               @relation("IssueCreatedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedBy    User?              @relation("IssueApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  items         IssueRequestItem[]
  toolItems     IssueRequestToolItem[]
  operations    Operation[]
  waybills      TransportWaybill[]
  stockMovements StockMovement[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([createdAt])
  @@index([warehouseId, section, createdAt])
}

model ObjectLimitTemplate {
  id           String          @id @default(cuid())
  warehouseId  String
  section      ObjectSection
  title        String
  sourceFileName String?
  createdById  String?
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy    User?           @relation("LimitTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  nodes        ObjectLimitNode[]
  receiptRequests ReceiptRequest[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([warehouseId, section, createdAt])
}

model ObjectLimitNode {
  id           String            @id @default(cuid())
  templateId   String
  parentId     String?
  orderNo      Int               @default(0)
  nodeType     LimitNodeType     @default(GROUP)
  indexLabel   String?
  title        String
  materialName String?
  unit         String?
  plannedQty   Decimal?          @db.Decimal(14, 3)
  issuedQty    Decimal           @default(0) @db.Decimal(14, 3)
  transferredOutQty Decimal      @default(0) @db.Decimal(14, 3)
  materialId   String?
  nameAlertNote String?
  template     ObjectLimitTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent       ObjectLimitNode?  @relation("LimitNodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     ObjectLimitNode[] @relation("LimitNodeTree")
  material     Material?         @relation(fields: [materialId], references: [id], onDelete: SetNull)
  receiptRequestItems ReceiptRequestItem[]
  issueRequestItems   IssueRequestItem[]
  transferRequestLines TransferRequestLine[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([templateId, parentId, orderNo])
}

model MaterialMappingLibrary {
  id               String        @id @default(cuid())
  warehouseId      String
  section          ObjectSection
  sourceName       String
  sourceUnit       String         @default("")
  targetMaterialId String
  createdById      String?
  warehouse        Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  targetMaterial   Material      @relation(fields: [targetMaterialId], references: [id], onDelete: Cascade)
  createdBy        User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([warehouseId, section, sourceName, sourceUnit])
  @@index([warehouseId, section, createdAt])
}

model ReceiptRequest {
  id                    String             @id @default(cuid())
  number                String
  warehouseId           String
  section               ObjectSection
  status                ReceiptRequestStatus @default(NEW)
  sourceFileName        String?
  createdById           String?
  acceptedAt            DateTime?
  fromLimit             Boolean            @default(false)
  objectLimitTemplateId String?
  externalOrderNumber   String?
  warehouse             Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy             User?              @relation("ReceiptRequestCreator", fields: [createdById], references: [id], onDelete: SetNull)
  limitTemplate         ObjectLimitTemplate? @relation(fields: [objectLimitTemplateId], references: [id], onDelete: SetNull)
  items                 ReceiptRequestItem[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([warehouseId, number])
  @@index([warehouseId, section, status, createdAt])
  @@index([objectLimitTemplateId])
  @@index([warehouseId, section, externalOrderNumber])
  @@index([warehouseId, sourceFileName])
}

model ReceiptRequestItem {
  id               String         @id @default(cuid())
  receiptRequestId String
  sourceName       String
  sourceUnit       String         @default("шт")
  quantity         Decimal        @db.Decimal(14, 3)
  mappedMaterialId String?
  limitNodeId      String?
  acceptedQty      Decimal?       @db.Decimal(14, 3)
  note             String?
  category         ReceiptItemCategory?
  unitPrice        Decimal?       @db.Decimal(14, 2)
  storagePlace     String?
  limitSectionPath String?
  namePartD        String?
  namePartE        String?
  limitCatalogNameN String?
  limitCatalogNameO String?
  externalComment  String?
  limitNameRenamed Boolean        @default(false)
  /// Фактическое наименование по УПД (выдача/склад); не меняет номенклатуру карточки и лимит.
  factLabel        String?
  factUnit         String?
  receiptRequest   ReceiptRequest @relation(fields: [receiptRequestId], references: [id], onDelete: Cascade)
  mappedMaterial   Material?      @relation(fields: [mappedMaterialId], references: [id], onDelete: SetNull)
  limitNode        ObjectLimitNode? @relation(fields: [limitNodeId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([receiptRequestId])
  @@index([limitNodeId])
}

model IssueRequestToolItem {
  id             String       @id @default(cuid())
  issueRequestId String
  toolId         String
  issueRequest   IssueRequest @relation(fields: [issueRequestId], references: [id], onDelete: Cascade)
  tool           Tool         @relation(fields: [toolId], references: [id], onDelete: Restrict)

  @@index([issueRequestId])
  @@index([toolId])
}

model IssueRequestItem {
  id             String       @id @default(cuid())
  issueRequestId String
  materialId     String
  /** Подпись в акте/печати: как в УПД/фактическая номенклатура; если null — номенклатура карточки материала */
  factLabel      String?
  /** Подраздел лимита, в который относится выдача (приход может быть в другом узле) */
  limitNodeId    String?
  quantity       Decimal      @db.Decimal(14, 3)
  /** Возвращено на склад после выдачи */
  returnedQty    Decimal      @default(0) @db.Decimal(14, 3)
  issueRequest   IssueRequest @relation(fields: [issueRequestId], references: [id], onDelete: Cascade)
  material       Material     @relation(fields: [materialId], references: [id], onDelete: Restrict)
  limitNode      ObjectLimitNode? @relation(fields: [limitNodeId], references: [id], onDelete: SetNull)

  @@index([issueRequestId])
  @@index([limitNodeId])
}

model TransportWaybill {
  id                 String                @id @default(cuid())
  number             String                @unique
  status             TransportWaybillStatus @default(DRAFT)
  fromWarehouseId    String?
  toLocation         String
  sender             String?
  recipient          String?
  vehicle            String?
  driverName         String?
  route              String?
  operationId        String?
  issueRequestId     String?
  shippedAt          DateTime?
  receivedAt         DateTime?
  closedAt           DateTime?
  fromWarehouse      Warehouse?            @relation("WaybillFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  operation          Operation?            @relation(fields: [operationId], references: [id], onDelete: SetNull)
  issueRequest       IssueRequest?         @relation(fields: [issueRequestId], references: [id], onDelete: SetNull)
  items              TransportWaybillItem[]
  events             TransportWaybillEvent[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model TransportWaybillItem {
  id                 String            @id @default(cuid())
  transportWaybillId String
  materialId         String
  quantity           Decimal           @db.Decimal(14, 3)
  transportWaybill   TransportWaybill  @relation(fields: [transportWaybillId], references: [id], onDelete: Cascade)
  material           Material          @relation(fields: [materialId], references: [id], onDelete: Restrict)
}

model TransportWaybillEvent {
  id                 String            @id @default(cuid())
  transportWaybillId String
  status             TransportWaybillStatus
  comment            String?
  createdAt          DateTime          @default(now())
  transportWaybill   TransportWaybill  @relation(fields: [transportWaybillId], references: [id], onDelete: Cascade)
}

enum CampItemCategory {
  CONTAINER_CABIN
  FURNITURE
  OFFICE_EQUIPMENT
  APPLIANCES
  OTHER
}

enum CampItemStatus {
  IN_USE
  STORAGE
  REPAIR
  WRITTEN_OFF
}

model CampItem {
  id              String            @id @default(cuid())
  name            String
  category        CampItemCategory  @default(OTHER)
  inventoryNumber String?
  serialNumber    String?
  manufacturer    String?
  location        String?
  description     String?
  warehouseId     String?
  section         ObjectSection     @default(SS)
  status          CampItemStatus    @default(IN_USE)
  acquiredAt      DateTime?
  createdById     String?
  warehouse       Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy       User?             @relation("CampItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([warehouseId, section])
  @@index([inventoryNumber])
}

/// Таблица выработки (Excel) по объекту и разделу СС/ЭОМ.
model ProductivitySheet {
  id             String        @id @default(cuid())
  warehouseId    String
  section        ObjectSection
  title          String
  sourceFileName String
  storagePath    String
  headerRow      Int           @default(1)
  dataStartRow   Int           @default(5)
  fixedColCount  Int           @default(7)
  dateColumns    Json
  cellValues     Json          @default("{}")
  createdById    String?
  warehouse      Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy      User?         @relation("ProductivitySheetCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([warehouseId, section])
  @@index([warehouseId, section, updatedAt])
}
